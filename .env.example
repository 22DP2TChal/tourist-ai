# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost/ai_tourist

# JWT secret key — generate a random string, e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Maps JavaScript API key — get one at https://console.cloud.google.com
# Enable: Maps JavaScript API, Geocoding API
GOOGLE_MAPS_API_KEY=AIza...
